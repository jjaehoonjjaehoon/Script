    def check_sftp_log_exists(date):
        try:
            transport = paramiko.Transport((SFTP_HOST, SFTP_PORT))
            transport.connect(username=SFTP_USERNAME, password=SFTP_PASSWORD)
            sftp = paramiko.SFTPClient.from_transport(transport)
            log_path = SFTP_LOG_PATH.format(date=date)
            try:
                sftp.stat(log_path)
                print(f"SFTP에 로그 파일 존재: {log_path}")
                return True
            except FileNotFoundError:
                print(f"SFTP에 해당 로그 파일 없음: {log_path}")
                return False
            finally:
                sftp.close()
                transport.close()
        except Exception as e:
            print(f"SFTP 연결 오류: {e}")
            return False

    def extract_ipv4_addresses(json_path, target_ids):
        with open(json_path, "r", encoding="utf-8") as file:
            data = json.load(file)
        ipv4_dict = {}
        for item in data.get("values", []):
            if item.get("id") in target_ids:
                prefixes = item.get("properties", {}).get("addressPrefixes", [])
                ips = [ip.strip() for ip in prefixes if isinstance(ip, str) and "." in ip]
                if ips:
                    ipv4_dict[item["id"]] = ips
        return ipv4_dict

    def save_to_sftp(ipv4_dict, date_str):

            for id, ips in ipv4_dict.items():
                remote_file_path = f"/logs/web/{id}_{date_str}.txt"
                content = "\n".join(ips)  # 마지막 빈 줄 제거
                print(f"업로드 시도: {remote_file_path}")
                try:
                    with sftp.open(remote_file_path, "w") as remote_file:
                        remote_file.write(content.encode("utf-8"))
                    print(f"업로드 성공: {remote_file_path}")
                except Exception as e:
                    print(f"업로드 실패: {e}")
            sftp.close()
            transport.close()
        except Exception as e:
            print(f"전체 업로드 실패: {e}")

